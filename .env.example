# Entorno de variables para Supabase
# Renombrar este archivo a .env en un entorno local si se usa un bundler (Vite/Webpack)
# o configurar directamente en los settings de Vercel (Project Settings > Environment Variables).

# URL del proyecto en Supabase (ej: https://[YOUR_PROJECT_REF].supabase.co)
VITE_SUPABASE_URL=

# Llave anónima pública de Supabase (empieza con 'sb_publishable_' o 'eyJhb...')
VITE_SUPABASE_KEY=
